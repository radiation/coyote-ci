                    "application/json"
                ],
                "tags": [
                    "builds"
                ],
                "summary": "Get build step logs",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Build ID",
                        "name": "buildID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Step index",
                        "name": "stepIndex",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Replay cursor (exclusive sequence number)",
                        "name": "after",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Maximum chunks to return",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
