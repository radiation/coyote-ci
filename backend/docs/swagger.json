                "tags": [
                    "builds"
                ],
                "summary": "Stream build step logs",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Build ID",
                        "name": "buildID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Step index",
                        "name": "stepIndex",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Replay cursor (exclusive sequence number)",
                        "name": "after",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "SSE stream",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
