# ─── Coyote CI environment variables ───
# Copy to .env and adjust as needed.
# Docker Compose reads this file automatically.

# ── Compose profile ──
# "dev"  = hot-reload backend + Vite frontend (default for local development)
# "prod" = production-like built images
COMPOSE_PROFILES=dev

# ── Go version (build arg for Compose) ──
# Must match backend/go.mod toolchain directive.
# GO_VERSION=1.26.1

# ── Server ──
APP_PORT=8080

# ── PostgreSQL ──
# Preferred for external/managed Postgres deployments:
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require
#
# Fallback for local/dev compose and split-field configuration:
DB_HOST=db
DB_PORT=5432
DB_USER=coyote
DB_PASSWORD=coyote
DB_NAME=coyote_ci
DB_SSLMODE=disable
# Connection pool tuning (Go duration format, e.g. 30m, 10m, 1h)
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m

# ── Worker ──
WORKER_STEP_LEASE_SECONDS=45
# WORKER_STATUS_ADDR=127.0.0.1:9091
WORKER_EXECUTION_BACKEND=docker
WORKER_EXECUTION_DEFAULT_IMAGE=alpine:3.20
# WORKER_EXECUTION_WORKSPACE_ROOT=/tmp/coyote-builds
# WORKER_MOUNT_DOCKER_SOCKET=false

# ── Artifacts ──
ARTIFACT_STORAGE_ROOT=/var/lib/coyote-artifacts
ARTIFACT_STORAGE_PROVIDER=filesystem
# ARTIFACT_STORAGE_STRICT=false

# ── Artifacts (GCS — only when ARTIFACT_STORAGE_PROVIDER=gcs) ──
# ARTIFACT_GCS_BUCKET=
# ARTIFACT_GCS_PREFIX=
# ARTIFACT_GCS_PROJECT=
# Credentials are provided via Google Application Default Credentials (ADC),
# workload identity, or service-account key injection in deployment tooling.

# ── Webhooks ──
GITHUB_WEBHOOK_SECRET=change-me
# PUSH_EVENT_SECRET=           # legacy; falls back from GITHUB_WEBHOOK_SECRET
