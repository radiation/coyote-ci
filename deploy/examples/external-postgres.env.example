# External Postgres runtime configuration example
# Copy values into your deployment environment for BOTH backend and worker.

# Preferred single DSN/URL for managed Postgres
DATABASE_URL=postgres://coyote_app:replace-me@db.example.internal:5432/coyote_ci?sslmode=require

# Optional pool tuning
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m

# Required application secrets
GITHUB_WEBHOOK_SECRET=replace-me
