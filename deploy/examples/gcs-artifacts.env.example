# Artifact blob storage on GCS (set for BOTH backend and worker)

# Store selection
ARTIFACT_STORAGE_PROVIDER=gcs
ARTIFACT_STORAGE_STRICT=true

# GCS configuration
ARTIFACT_GCS_BUCKET=coyote-artifacts-prod
ARTIFACT_GCS_PREFIX=coyote-ci
# ARTIFACT_GCS_PROJECT=optional-project-id

# Credentials should come from runtime identity/secret injection,
# not hardcoded environment values committed to git.
